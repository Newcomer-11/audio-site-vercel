# ── Bắt buộc ──────────────────────────────────────────────────────────────
# Mật khẩu trang admin
ADMIN_PASSWORD=your_strong_password_here

# Chuỗi bí mật ký cookie (random string dài)
SESSION_SECRET=random_long_secret_string_here

# Vercel Blob token — tự động có khi enable Blob Storage trong Vercel Dashboard
# Hoặc tạo thủ công: Vercel Dashboard → Storage → Create Blob Store → lấy token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx
