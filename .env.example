# Vercel Environment Variables
# Vào Vercel Dashboard > Settings > Environment Variables để set các biến này

# Mật khẩu trang admin
ADMIN_PASSWORD=your_strong_password_here

# Chuỗi bí mật để ký cookie (đặt random string dài)
SESSION_SECRET=random_long_secret_string_here

# ── Cloudinary (bắt buộc để upload/stream audio) ──────────────────────────
# Đăng ký miễn phí tại: https://cloudinary.com
# Vào Dashboard > API Keys để lấy thông tin
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
